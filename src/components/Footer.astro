---
/**
 * Sitewide footer — privacy reassurance line, nav columns, trust pages,
 * GitHub link, copyright. All strings from site.config.ts.
 */
import { site } from "../site.config";

const year = new Date().getFullYear();

interface FooterLink {
  href: string;
  label: string;
  external?: boolean;
}
interface FooterColumn {
  title: string;
  links: FooterLink[];
}

const columns: FooterColumn[] = [
  {
    title: "Product",
    links: [
      { href: "/app/", label: "Compress a video" },
      { href: "/how-it-works/", label: "How it works" },
      { href: "/faq/", label: "FAQ" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about/", label: "About" },
      { href: "/contact/", label: "Contact" },
      { href: site.githubRepo, label: "GitHub", external: true },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/privacy/", label: "Privacy Policy" },
      { href: "/terms/", label: "Terms" },
    ],
  },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      {/* Brand + reassurance */}
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
          <span
            class="inline-flex size-7 items-center justify-center rounded-md text-[var(--color-accent)]"
            style="background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m22 8-6 4 6 4V8Z"></path>
              <rect width="14" height="12" x="2" y="6" rx="2" ry="2"></rect>
              <path d="M9 9v6"></path>
              <path d="m7 11 2 2 2-2"></path>
            </svg>
          </span>
          <span>{site.shortName}</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-fg-muted)]">
          Compress video right in your browser. Your files never leave your
          device — no upload, no signup, no watermark.
        </p>
      </div>

      {/* Link columns */}
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
        {
          columns.map((col) => (
            <div>
              <h2 class="text-sm font-semibold text-[var(--color-fg)]">
                {col.title}
              </h2>
              <ul class="mt-3 space-y-2">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-[var(--color-fg-muted)] transition-colors hover:text-[var(--color-fg)]"
                      {...(link.external
                        ? { target: "_blank", rel: "noopener noreferrer" }
                        : {})}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-3 border-t border-[var(--color-border)] pt-6 text-sm text-[var(--color-fg-subtle)] sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}. Free forever.</p>
      <p class="inline-flex items-center gap-1.5">
        {/* Lucide "shield-check" — privacy reassurance */}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
          <path d="m9 12 2 2 4-4"></path>
        </svg>
        100% on-device · nothing uploaded
      </p>
    </div>
  </div>
</footer>
