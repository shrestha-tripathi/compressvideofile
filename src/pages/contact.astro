---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.config";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${site.url}/contact#contact`,
  url: `${site.url}/contact/`,
  name: `Contact ${site.name}`,
  publisher: { "@id": `${site.url}/#organization` },
};
---

<Layout
  title="Contact"
  description={`Get in touch about ${site.name} — questions, bug reports, or feature ideas.`}
  path="/contact/"
  jsonLd={[contactSchema]}
>
  <Header />

  <main class="mx-auto max-w-[680px] px-6 md:px-12 py-16 md:py-24">
    <p class="text-sm uppercase tracking-[0.06em] text-[var(--color-fg-subtle)]">Contact</p>
    <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight">Get in touch</h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)]">
      {site.name} is an independent project. Questions, bug reports and feature
      ideas are all welcome.
    </p>

    <div class="mt-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6 md:p-8">
      <h2 class="text-lg font-semibold text-[var(--color-fg)]">Email</h2>
      <p class="mt-2 text-[var(--color-fg-muted)]">
        The fastest way to reach the maker:
      </p>
      <a
        href={`mailto:${site.contactEmail}`}
        class="mt-3 inline-flex items-center gap-2 text-[var(--color-accent)] underline"
      >
        {site.contactEmail}
      </a>
    </div>

    <div class="mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6 md:p-8">
      <h2 class="text-lg font-semibold text-[var(--color-fg)]">Report an issue</h2>
      <p class="mt-2 text-[var(--color-fg-muted)]">
        Found a video that won't compress, or a format that fails? Open an issue on
        GitHub with the file type, size and your browser — it helps a lot.
      </p>
      <a
        href={site.githubRepo}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-flex items-center gap-2 text-[var(--color-accent)] underline"
      >
        {site.githubRepo.replace("https://", "")}
      </a>
    </div>

    <p class="mt-10 text-sm text-[var(--color-fg-subtle)]">
      Note: because compression happens entirely in your browser, we can't see or
      recover any video you've worked on — nothing is ever uploaded to us.
    </p>
  </main>

  <Footer />
</Layout>
