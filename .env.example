# ---------------------------------------------------------------------------
# Compress Video File — environment variables (all OPTIONAL; sane defaults in
# src/site.config.ts). Copy to `.env` and override per-deploy as needed.
#
# Brand strings are env-driven so a domain rename is a `.env`-only change.
# The .pages.dev guard in site.config.ts rejects any *.pages.dev value here.
# ---------------------------------------------------------------------------

# Canonical site origin (protocol + domain, no trailing slash).
PUBLIC_SITE_URL=https://compressvideofile.com

# Bare domain (no protocol) — shown in copy + used in robots/sitemap.
PUBLIC_SITE_DOMAIN=compressvideofile.com

# Brand names.
PUBLIC_SITE_NAME=Compress Video File
PUBLIC_SITE_SHORT_NAME=Compress Video

# Short tagline (feeds homepage <title> + OG alt).
PUBLIC_SITE_TAGLINE=Compress video in your browser — no upload

# Meta description (<160 chars ideal).
PUBLIC_SITE_DESCRIPTION=Free online video compressor that works 100% in your browser. Shrink MP4, MOV, WebM files for WhatsApp, email or Discord — your video never leaves your device. No upload, no watermark, no signup.

# Trust-page contact email.
PUBLIC_SITE_CONTACT_EMAIL=shrestha.tripathi@gmail.com

# Public source repo.
PUBLIC_SITE_GITHUB_REPO=https://github.com/shrestha-tripathi/compressvideofile

# Governing-law jurisdiction for Terms.
PUBLIC_SITE_JURISDICTION=India

# Google Analytics 4 Measurement ID (format G-XXXXXXXXXX). Leave EMPTY to
# disable analytics entirely. Only injected in production builds.
PUBLIC_GA_MEASUREMENT_ID=
